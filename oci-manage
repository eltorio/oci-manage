        sh -c "yq $_CMD_ < $OCI_DB"
    fi
}

function cluster_ping_host_from_members() {
    if [ "$#" -ne 1 ]; then
        echo "Illegal number of parameters:" && echo "    usage cluster_ping_host_from_members host"
    else
        HOST=$1
        for MEMBER in $CLUSTER_MEMBERS; do
            ssh $USER@$MEMBER "ping -c1 $HOST"
