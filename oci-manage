        sudo -u "$USERNAME" sh -c "cd &&\
                                   mkdir -p .ssh &&\
                                   chmod go-rwx .ssh &&\
                                   ssh-keygen -q -t ecdsa -f ~/.ssh/id_ecdsa -N ''"
    fi
}

