  RES=""
  for NAME in ${TRAEFIK_DASHBOARD_DNS_NAMES[@]}; do RES+="Host(\`$NAME\`) || "; done
  RULES="${RES:0:-3}"
  MATCH="(((PathPrefix(\`/api\`) || PathPrefix(\`/dashboard\`))) && ($RULES) )"
  CN=${TRAEFIK_DASHBOARD_DNS_NAMES[0]}
  cat <<EOF | kubectl $ACTION -f -
