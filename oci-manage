function cluster_get_traefik_lb_ip() {
    if [ "$#" -ne 0 ]; then
        echo "Illegal number of parameters:" && echo "    usage cluster_get_traefik_lb_ip"
    else
        #LB_IP=$(kubectl get services -A | awk '$2=="traefik" && $3=="LoadBalancer" {print $5}')
