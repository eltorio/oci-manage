    kind: ClusterIssuer
---
apiVersion: traefik.containo.us/v1alpha1
kind: Middleware
metadata:
  name: traefik-dashboard-auth
  namespace: kube-traefik
spec:
  basicAuth:
    secret: authsecret
---
apiVersion: traefik.containo.us/v1alpha1
kind: IngressRoute
metadata:
  name: traefik-dashboard
  namespace: kube-traefik
spec:
  entryPoints:
    - websecure
  routes:
    - match: $MATCH
      kind: Rule
      services:
      - name: api@internal
        kind: TraefikService
      middlewares:
      - name: traefik-dashboard-auth
  tls:
    secretName: traefik-dashboard-certs
---
EOF
}
